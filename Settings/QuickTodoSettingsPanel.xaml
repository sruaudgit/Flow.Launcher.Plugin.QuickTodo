<UserControl x:Class="Flow.Launcher.Plugin.QuickTodo.Settings.QuickTodoSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="16">
    <StackPanel>
        <TextBlock Text="Reminder Interval (minutes)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Text="{Binding ReminderIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                 Width="100" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <TextBlock Text="Snooze Duration (minutes)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Text="{Binding SnoozeDurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                 Width="100" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <CheckBox Content="Enable notification sound"
                  IsChecked="{Binding NotificationSoundEnabled}"
                  Margin="0,0,0,16"/>

        <TextBlock Text="Data Location" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox Text="{Binding DataFilePath, Mode=OneWay}" IsReadOnly="True"
                 Background="Transparent" BorderThickness="0" Margin="0,0,0,16"
                 Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>

        <TextBlock Text="Categories" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ListBox ItemsSource="{Binding Categories}" Height="120" Margin="0,0,0,8"
                 x:Name="CategoryList"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <TextBox Text="{Binding NewCategory, UpdateSourceTrigger=PropertyChanged}"
                     Width="150" Margin="0,0,8,0" x:Name="NewCategoryBox"/>
            <Button Content="Add" Click="AddCategory_Click" Width="60" Margin="0,0,8,0"/>
            <Button Content="Remove" Click="RemoveCategory_Click" Width="70"/>
        </StackPanel>
    </StackPanel>
</UserControl>
